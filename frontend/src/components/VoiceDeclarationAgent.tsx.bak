import React, { useState, useRef, useEffect, useCallback } from "react";
import axios from "axios";
import {
  Mic, MicOff, Send, Volume2, VolumeX, RefreshCw, CheckCircle,
  XCircle, Loader2, AlertCircle, Truck, MapPin, Calendar,
  Wrench, Shield, FileText, MessageCircle, Bot, User
} from "lucide-react";

const API = "http://localhost:8080";

const Recognition = (window as any).SpeechRecognition || (window as any).webkitSpeechRecognition;
const synth = typeof window !== "undefined" ? window.speechSynthesis : null;

const DARIJA_TO_ARABIC: Record<string, string> = {
  "n3ammar": "Ù†Ø¹Ù…Ù‘Ø±", "bghit": "Ø¨ØºÙŠØª", "wach": "ÙˆØ§Ø´", "nta": "Ù†ØªØ§",
  "msta3ed": "Ù…Ø³ØªØ¹Ø¯", "mzyan": "Ù…Ø²ÙŠØ§Ù†", "khoya": "Ø®ÙˆÙŠØ§", "s7i7": "ØµØ­",
  "goul": "Ù‚ÙˆÙ„", "ghadi": "ØºØ§Ø¯ÙŠ", "nsawelk": "Ù†Ø³Ø§ÙˆÙ„Ùƒ",
  "naw3": "Ù†ÙˆØ¹", "dial": "Ø¯ÙŠØ§Ù„", "kayn": "ÙƒÙŠÙ†", "fin": "ÙÙŠÙ†",
  "imta": "ÙŠÙ…ØªØ§", "lyouma": "Ø§Ù„ÙŠÙˆÙ…", "bari7": "Ø§Ù„Ø¨Ø§Ø±Ø­",
  "3awed": "Ø¹Ø§ÙˆØ¯", "t3awed": "ØªØ¹Ø§ÙˆØ¯", "mashi": "Ù…Ø§Ø´ÙŠ", "walou": "ÙˆØ§Ù„Ùˆ",
  "wakha": "ÙˆØ§Ø®Ø§", "wah": "ÙˆØ§Ù‡", "ah": "Ø¢Ù‡", "oui": "ÙˆÙŠ", "na3am": "Ù†Ø¹Ù…",
  "t9eb": "ØªÙ‚Ø¨", "tbriya": "Ø·Ø¨Ø±ÙŠØ©", "cassat": "ÙƒØµØ§Øª", "casse": "ÙƒØµ",
  "kadour": "ÙƒÙŠØ¯ÙˆØ±", "kaydir": "ÙƒØ§ÙŠØ¯ÙŠØ±", "lfaran": "Ø§Ù„ÙØ±Ø§Ù†",
  "l9eddan": "Ø§Ù„Ù‚Ø¯Ø§Ù…", "lkhoura": "Ø§Ù„Ø®Ù„ÙØ©", "s3a": "Ø³Ø§Ø¹Ø©",
  "kifash": "ÙƒÙŠÙØ§Ø´", "kifach": "ÙƒÙŠÙØ§Ø´", "3lach": "Ø¹Ù„Ø§Ø´",
  "m3ak": "Ù…Ø¹Ø§Ùƒ", "m3akom": "Ù…Ø¹Ø§ÙƒÙ…", "btabt": "Ø¨Ø¯Ù‚Ø©", "bdabt": "Ø¨Ø¯Ù‚Ø©",
  "hadchi": "Ù‡Ø§Ø¯Ø´ÙŠ", "3andek": "Ø¹Ù†Ø¯Ùƒ", "3andna": "Ø¹Ù†Ø¯Ù†Ø§",
  "ma9f": "Ù…ÙˆÙ‚Ù", "wa9ef": "ÙˆØ§Ù‚Ù", "b9a": "Ø¨Ù‚Ù‰", "b9it": "Ø¨Ù‚ÙŠØª",
  "makaynch": "Ù…Ø§ÙƒÙŠÙ†Ø´", "3ti": "Ø¹Ø·ÙŠ", "3tik": "Ù†Ø¹Ø·ÙŠÙƒ",
  "sm7 lia": "Ø³Ù…Ø­ Ù„ÙŠØ§", "nssajel": "Ù†Ø³Ø¬Ù‘Ù„", "l3ammar": "Ù„Ø¹Ù…Ù‘Ø§Ø±",
  "b7al": "Ø¨Ø­Ø§Ù„", "dyal": "Ø¯ÙŠØ§Ù„", "3ammar": "Ø¹Ù…Ù‘Ø±",
};

function transliterateDarija(text: string): string {
  let result = text;
  const sortedKeys = Object.keys(DARIJA_TO_ARABIC).sort((a, b) => b.length - a.length);
  for (const key of sortedKeys) {
    result = result.replace(new RegExp(key.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'), 'gi'), DARIJA_TO_ARABIC[key]);
  }
  result = result
    .replace(/3/g, "Ø¹").replace(/7/g, "Ø­").replace(/9/g, "Ù‚").replace(/5/g, "Ø®")
    .replace(/6/g, "Ø·");
  const latinParts = result.split(/([\u0600-\u06FF]+|[a-zA-ZÃ€-Ã¿0-9.,!?;:'"()\-/\\]+)/);
  const processed = latinParts.map(part => {
    if (/^[a-zA-ZÃ€-Ã¿]/.test(part)) {
      return part.replace(/ch/g, "Ø´").replace(/kh/g, "Ø®").replace(/gh/g, "Øº")
        .replace(/aa/g, "Ø§").replace(/ee/g, "ÙŠ").replace(/oo/g, "Ùˆ").replace(/ou/g, "Ùˆ")
        .replace(/a/g, "Ø§").replace(/i/g, "ÙŠ").replace(/u/g, "Ùˆ").replace(/e/g, "ÙŠ").replace(/o/g, "Ùˆ");
    }
    return part;
  });
  return processed.join('');
}

interface ChatMsg {
  type: "ai" | "user";
  text: string;
  textFr?: string;
  timestamp: Date;
}

interface VoiceDeclarationAgentProps {
  currentUser?: { id?: number; name?: string; firstname?: string; matricule?: string } | null;
  onDeclarationCreated?: (declaration: any) => void;
}

interface VoiceAgentResponse {
  sessionId?: string;
  step?: number;
  field?: string;
  questionDarija?: string;
  questionFrancais?: string;
  done?: boolean;
  cancelled?: boolean;
  retry?: boolean;
  retryMessage?: string;
  retryMessageFr?: string;
  error?: string;
  declarationCreated?: boolean;
  declarationId?: number;
  declaration?: any;
  formData?: Record<string, string>;
  choices?: string[];
}

const STEP_ICONS: Record<string, React.ReactNode> = {
  greeting: <MessageCircle className="w-4 h-4" />,
  vehicule: <Truck className="w-4 h-4" />,
  immatriculation: <Truck className="w-4 h-4" />,
  typePanne: <Wrench className="w-4 h-4" />,
  elementVehicule: <Wrench className="w-4 h-4" />,
  detailElement: <Wrench className="w-4 h-4" />,
  criticite: <Shield className="w-4 h-4" />,
  location: <MapPin className="w-4 h-4" />,
  dateHeure: <Calendar className="w-4 h-4" />,
  description: <FileText className="w-4 h-4" />,
  kilometrage: <Truck className="w-4 h-4" />,
  source: <FileText className="w-4 h-4" />,
  confirmation: <CheckCircle className="w-4 h-4" />,
};

export default function VoiceDeclarationAgent({ currentUser, onDeclarationCreated }: VoiceDeclarationAgentProps) {
  const [sessionId, setSessionId] = useState<string>("");
  const [step, setStep] = useState(0);
  const [field, setField] = useState("greeting");
  const [questionDarija, setQuestionDarija] = useState("");
  const [questionFrancais, setQuestionFrancais] = useState("");
  const [formData, setFormData] = useState<Record<string, string>>({});
  const [choices, setChoices] = useState<string[]>([]);
  const [chatHistory, setChatHistory] = useState<ChatMsg[]>([]);
  const [listening, setListening] = useState(false);
  const [speaking, setSpeaking] = useState(false);
  const [loading, setLoading] = useState(false);
  const [done, setDone] = useState(false);
  const [declarationId, setDeclarationId] = useState<number | null>(null);
  const [declarationCreated, setDeclarationCreated] = useState(false);
  const [retry, setRetry] = useState(false);
  const [retryMsg, setRetryMsg] = useState("");
  const [cancelled, setCancelled] = useState(false);
  const [muted, setMuted] = useState(false);
  const [inputText, setInputText] = useState("");

  const recognitionRef = useRef<any>(null);
  const chatEndRef = useRef<HTMLDivElement>(null);

  useEffect(() => {
    chatEndRef.current?.scrollIntoView({ behavior: "smooth" });
  }, [chatHistory]);

  useEffect(() => {
    if (questionDarija && !muted && !done) {
      speakDarija(questionDarija);
    }
  }, [questionDarija]);

  function speakDarija(text: string): Promise<void> {
    return new Promise((resolve) => {
      if (!synth || !text.trim()) { resolve(); return; }
      try { synth.cancel(); } catch {}

      const arabicText = transliterateDarija(text);

      const speakSequence = (texts: string[], idx: number) => {
        if (idx >= texts.length || !texts[idx].trim()) { setSpeaking(false); resolve(); return; }
        const u = new SpeechSynthesisUtterance(texts[idx]);
        const voices = synth.getVoices();
        const isArabic = /[\u0600-\u06FF]/.test(texts[idx]);
        u.lang = isArabic ? "ar-MA" : "fr-FR";
        u.rate = isArabic ? 0.85 : 0.9;
        u.pitch = isArabic ? 1.0 : 1.0;
        u.volume = 1.0;
        if (isArabic) {
          const arVoice = voices.find(v => v.lang === "ar-MA")
            || voices.find(v => v.lang.startsWith("ar"))
            || null;
          if (arVoice) u.voice = arVoice;
        } else {
          const frVoice = voices.find(v => v.lang === "fr-MA")
            || voices.find(v => v.lang === "fr-FR")
            || voices.find(v => v.lang.startsWith("fr"))
            || null;
          if (frVoice) u.voice = frVoice;
        }
        u.onend = () => speakSequence(texts, idx + 1);
        u.onerror = () => speakSequence(texts, idx + 1);
        try { synth.speak(u); } catch { speakSequence(texts, idx + 1); }
      };

      setSpeaking(true);
      const parts = arabicText.split(/([a-zA-ZÃ€-Ã¿][a-zA-ZÃ€-Ã¿0-9 .,!?;:'"()\-/\\]*)/);
      const segments = parts.filter(p => p.trim()).map(p => {
        if (/^[a-zA-ZÃ€-Ã¿]/.test(p)) return p;
        return p;
      });
      speakSequence(segments, 0);
    });
  }

  const startListening = useCallback(() => {
    if (!Recognition) return;
    if (listening) { stopListening(); return; }

    const recog = new Recognition();
    recog.lang = "ar-MA";
    recog.continuous = false;
    recog.interimResults = false;
    recog.maxAlternatives = 3;

    recog.onstart = () => setListening(true);
    recog.onend = () => setListening(false);
    recog.onerror = () => setListening(false);

    recog.onresult = (event: any) => {
      let transcript = "";
      for (let i = 0; i < event.results.length; i++) {
        for (let j = 0; j < event.results[i].length; j++) {
          const alt = event.results[i][j];
          if (alt.confidence > 0.4 || !transcript) {
            transcript = alt.transcript;
          }
        }
      }
      if (transcript.trim()) {
        handleUserResponse(transcript.trim());
      }
    };

    recog.start();
    recognitionRef.current = recog;
  }, [sessionId, step, listening, done]);

  const stopListening = useCallback(() => {
    if (recognitionRef.current) {
      try { recognitionRef.current.stop(); } catch {}
    }
    setListening(false);
  }, []);

  const handleUserResponse = async (text: string) => {
    if (loading || done) return;

    setChatHistory(prev => [...prev, { type: "user", text, timestamp: new Date() }]);
    setLoading(true);

    try {
      const res = await axios.post<VoiceAgentResponse>(`${API}/api/voice-agent/respond`, {
        sessionId,
        step,
        response: text,
      });

      const data = res.data;

      if (data.error) {
        setChatHistory(prev => [...prev, { type: "ai", text: data.error || "Erreur", timestamp: new Date() }]);
        setLoading(false);
        return;
      }

      if (data.cancelled) {
        setCancelled(true);
        setDone(true);
        setChatHistory(prev => [...prev, { type: "ai", text: data.questionDarija || data.questionFrancais || "DÃ©claration annulÃ©e", textFr: data.questionFrancais, timestamp: new Date() }]);
        setLoading(false);
        return;
      }

      if (data.declarationCreated && data.declarationId) {
        setDeclarationId(data.declarationId);
        setDeclarationCreated(true);
        setDone(true);
        setFormData(data.formData || {});
        setChatHistory(prev => [...prev, { type: "ai", text: data.questionDarija || data.questionFrancais || "DÃ©claration enregistrÃ©e", textFr: data.questionFrancais, timestamp: new Date() }]);
        if (onDeclarationCreated) onDeclarationCreated(data.declaration || data.formData);
        setLoading(false);
        return;
      }

      if (data.retry) {
        setRetry(true);
        setRetryMsg(data.retryMessage || "3awed 9ol liya...");
        setChatHistory(prev => [...prev, { type: "ai", text: data.retryMessage || "Ma fhamtch, 3awed goul", textFr: data.retryMessageFr, timestamp: new Date() }]);
      } else {
        setRetry(false);
        setRetryMsg("");
        setStep(data.step || step + 1);
        setField(data.field || "");
        setQuestionDarija(data.questionDarija || "");
        setQuestionFrancais(data.questionFrancais || "");
        setChoices(data.choices || []);
        setFormData(data.formData || formData);
        setChatHistory(prev => [...prev, { type: "ai", text: data.questionDarija || data.questionFrancais || "Question suivante", textFr: data.questionFrancais, timestamp: new Date() }]);
      }

      if (data.done) setDone(true);
    } catch (err: any) {
      setChatHistory(prev => [...prev, { type: "ai", text: "Mochkil f connexion. 3awed men b3d.", textFr: "Erreur de connexion. RÃ©essayez.", timestamp: new Date() }]);
    } finally {
      setLoading(false);
    }
  };

  const startSession = async () => {
    setLoading(true);
    setChatHistory([]);
    setDone(false);
    setDeclarationCreated(false);
    setCancelled(false);
    setDeclarationId(null);
    setFormData({});

    try {
      const res = await axios.post<VoiceAgentResponse>(`${API}/api/voice-agent/start`, {
        chauffeurId: currentUser?.id || 0,
        chauffeurNom: currentUser?.name || currentUser?.firstname || "Chauffeur",
        chauffeurMatricule: currentUser?.matricule || "",
      });

      const data = res.data;
      setSessionId(data.sessionId || "");
      setStep(data.step || 1);
      setField(data.field || "greeting");
      setQuestionDarija(data.questionDarija || "");
      setQuestionFrancais(data.questionFrancais || "");
      setChoices(data.choices || []);
      setChatHistory([{ type: "ai", text: data.questionDarija || data.questionFrancais || "Salam, nbdaou?", textFr: data.questionFrancais, timestamp: new Date() }]);
    } catch {
      setChatHistory([{ type: "ai", text: "Mochkil f connexion. 3awed t3awed.", textFr: "Erreur de connexion. RÃ©essayez.", timestamp: new Date() }]);
    } finally {
      setLoading(false);
    }
  };

  const selectChoice = (choice: string) => {
    handleUserResponse(choice);
  };

  const sendTextInput = () => {
    if (!inputText.trim()) return;
    handleUserResponse(inputText.trim());
    setInputText("");
  };

  const progressPercent = step > 0 ? Math.min(Math.round((step / 12) * 100), 100) : 0;

  return (
    <div className="max-w-2xl mx-auto p-4 space-y-4">
      {/* Header */}
      <div className="bg-gradient-to-r from-blue-600 to-indigo-700 rounded-2xl p-4 text-white shadow-lg">
        <div className="flex items-center justify-between">
          <div className="flex items-center gap-3">
            <div className="w-12 h-12 bg-white/20 rounded-xl flex items-center justify-center">
              <Mic className="w-6 h-6" />
            </div>
            <div>
              <h1 className="text-lg font-bold">Agent IA Vocal - Agent ØµÙˆØªÙŠ Ø°ÙƒÙŠ</h1>
              <p className="text-xs text-blue-100">DÃ©claration par la voix â€” 3ammar b sawtk!</p>
            </div>
          </div>
          <button onClick={() => setMuted(!muted)} className="p-2 rounded-lg hover:bg-white/20 transition-colors" title={muted ? "Activer le son" : "DÃ©sactiver le son"}>
            {muted ? <VolumeX className="w-5 h-5" /> : <Volume2 className="w-5 h-5" />}
          </button>
        </div>

        {/* Progress */}
        {!done && step > 0 && (
          <div className="mt-3">
            <div className="flex items-center justify-between text-xs text-blue-100 mb-1">
              <span>Ã‰tape {step}/12</span>
              <span>{progressPercent}%</span>
            </div>
            <div className="w-full bg-white/20 rounded-full h-2">
              <div className="bg-white rounded-full h-2 transition-all duration-500" style={{ width: `${progressPercent}%` }} />
            </div>
          </div>
        )}
      </div>

      {/* Session not started */}
      {!sessionId && !done && (
        <div className="bg-white dark:bg-gray-800 rounded-2xl shadow-lg border border-gray-200 dark:border-gray-700 p-8 text-center">
          <div className="w-20 h-20 mx-auto bg-blue-50 dark:bg-blue-900/30 rounded-full flex items-center justify-center mb-4">
            <Mic className="w-10 h-10 text-blue-500" />
          </div>
          <h2 className="text-xl font-bold text-gray-800 dark:text-white mb-2">DÃ©claration Vocale</h2>
          <p className="text-sm text-gray-500 dark:text-gray-400 mb-2">Agent IA Ø¨Ø§Ù„Ø¯Ø§Ø±Ø¬Ø© â€” 3ammar l'dÃ©claration b sawtk bla ma tekteb walo</p>
          <p className="text-xs text-gray-400 dark:text-gray-500 mb-6">L'agent IA vous guidera Ã©tape par Ã©tape en Darija marocaine</p>

          <div className="space-y-2 mb-6 text-left bg-gray-50 dark:bg-gray-900 rounded-xl p-4">
            <div className="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-300"><Truck className="w-4 h-4 text-blue-500" /> Identifier le vÃ©hicule</div>
            <div className="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-300"><Wrench className="w-4 h-4 text-orange-500" /> DÃ©crire le type de panne</div>
            <div className="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-300"><MapPin className="w-4 h-4 text-green-500" /> Indiquer le lieu</div>
            <div className="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-300"><CheckCircle className="w-4 h-4 text-emerald-500" /> Confirmer et valider</div>
          </div>

          <button onClick={startSession} disabled={loading}
            className="px-8 py-3 bg-gradient-to-r from-blue-500 to-indigo-600 text-white rounded-xl font-bold text-base shadow-lg hover:scale-[1.02] transition-all disabled:opacity-50 flex items-center gap-2 mx-auto">
            {loading ? <Loader2 className="w-5 h-5 animate-spin" /> : <Mic className="w-5 h-5" />}
            Commencer la DÃ©claration Vocale
          </button>
        </div>
      )}

      {/* Chat Interface */}
      {sessionId && !done && (
        <div className="space-y-3">
          {/* Current question */}
          {questionDarija && (
            <div className="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-2xl p-4">
              <div className="flex items-start gap-3">
                <div className="w-10 h-10 bg-blue-500 rounded-full flex items-center justify-center shrink-0">
                  <Bot className="w-5 h-5 text-white" />
                </div>
                <div className="flex-1">
                  <p className="text-base font-bold text-blue-800 dark:text-blue-200" dir="rtl">{questionDarija}</p>
                  {questionFrancais && questionFrancais !== questionDarija && (
                    <p className="text-sm text-blue-600 dark:text-blue-300 mt-1">{questionFrancais}</p>
                  )}
                  {retry && retryMsg && (
                    <p className="text-xs text-amber-600 mt-1 flex items-center gap-1">
                      <AlertCircle className="w-3 h-3" /> {retryMsg}
                    </p>
                  )}
                </div>
                <div className="text-blue-400">{STEP_ICONS[field] || <MessageCircle className="w-4 h-4" />}</div>
              </div>
            </div>
          )}

          {/* Choices */}
          {choices.length > 0 && (
            <div className="grid grid-cols-2 sm:grid-cols-3 gap-2">
              {choices.map(choice => (
                <button key={choice} onClick={() => selectChoice(choice)}
                  className="px-3 py-2 bg-white dark:bg-gray-800 border-2 border-gray-200 dark:border-gray-600 rounded-xl text-sm font-medium text-gray-700 dark:text-gray-200 hover:border-blue-400 hover:bg-blue-50 dark:hover:bg-blue-900/30 transition-all">
                  {choice}
                </button>
              ))}
            </div>
          )}

          {/* Microphone + Text Input */}
          <div className="flex items-center gap-2">
            <button onClick={startListening}
              className={`w-14 h-14 rounded-full flex items-center justify-center transition-all shadow-lg ${
                listening ? "bg-red-500 hover:bg-red-600 animate-pulse" : "bg-gradient-to-r from-blue-500 to-indigo-600 hover:from-blue-600 hover:to-indigo-700"
              }`}
              disabled={loading || done}>
              {listening ? <MicOff className="w-6 h-6 text-white" /> : <Mic className="w-6 h-6 text-white" />}
            </button>

            <div className="flex-1 relative">
              <input type="text" value={inputText} onChange={e => setInputText(e.target.value)}
                onKeyDown={e => e.key === 'Enter' && sendTextInput()}
                placeholder={listening ? "ÙƒÙ†Ø³Ù…Ø¹Ùƒ... hdar daba" : "Ã‰crivez votre rÃ©ponse ici..."}
                className="w-full px-4 py-3 border-2 border-gray-200 dark:border-gray-600 rounded-xl text-sm bg-white dark:bg-gray-800 text-gray-800 dark:text-white focus:border-blue-400 focus:outline-none"
                disabled={loading || done} />
            </div>

            <button onClick={sendTextInput} disabled={!inputText.trim() || loading}
              className="w-14 h-14 bg-blue-500 hover:bg-blue-600 text-white rounded-xl flex items-center justify-center disabled:opacity-50 transition-all">
              <Send className="w-5 h-5" />
            </button>
          </div>

          {listening && (
            <div className="text-center text-sm text-blue-500 animate-pulse">
              ðŸŽ¤ ÙƒÙ†Ø³Ù…Ø¹Ùƒ... hdar daba
            </div>
          )}

          {/* Chat History */}
          {chatHistory.length > 1 && (
            <div className="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-2xl p-3 max-h-60 overflow-y-auto space-y-2">
              {chatHistory.slice(-8).map((msg, i) => (
                <div key={i} className={`flex items-start gap-2 ${msg.type === "user" ? "justify-end" : ""}`}>
                  {msg.type === "ai" && (
                    <div className="w-7 h-7 bg-blue-100 dark:bg-blue-900/50 rounded-full flex items-center justify-center shrink-0">
                      <Bot className="w-3.5 h-3.5 text-blue-500" />
                    </div>
                  )}
                  <div className={`max-w-[80%] px-3 py-2 rounded-xl text-sm ${
                    msg.type === "user"
                      ? "bg-indigo-500 text-white rounded-br-none"
                      : "bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-200 rounded-bl-none"
                  }`} dir={msg.type === "ai" ? "rtl" : "ltr"}>
                    {msg.text}
                    {msg.textFr && msg.type === "ai" && (
                      <p className="text-xs mt-1 opacity-70" dir="ltr">{msg.textFr}</p>
                    )}
                  </div>
                  {msg.type === "user" && (
                    <div className="w-7 h-7 bg-indigo-500 rounded-full flex items-center justify-center shrink-0">
                      <User className="w-3.5 h-3.5 text-white" />
                    </div>
                  )}
                </div>
              ))}
              <div ref={chatEndRef} />
            </div>
          )}

          {/* Collected data summary */}
          {Object.keys(formData).length > 0 && (
            <div className="bg-gray-50 dark:bg-gray-900 rounded-xl p-3">
              <p className="text-xs font-semibold text-gray-500 dark:text-gray-400 mb-2">DonnÃ©es collectÃ©es:</p>
              <div className="grid grid-cols-2 gap-1 text-xs">
                {Object.entries(formData).filter(([k, v]) => v && k !== "ready").map(([k, v]) => (
                  <div key={k} className="flex items-center gap-1">
                    <CheckCircle className="w-3 h-3 text-emerald-500" />
                    <span className="text-gray-600 dark:text-gray-300">{k}: <strong>{v}</strong></span>
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>
      )}

      {/* Declaration Created */}
      {declarationCreated && (
        <div className="bg-white dark:bg-gray-800 rounded-2xl shadow-lg border-2 border-emerald-300 dark:border-emerald-700 p-6 text-center">
          <div className="w-16 h-16 mx-auto bg-emerald-100 dark:bg-emerald-900/30 rounded-full flex items-center justify-center mb-4">
            <CheckCircle className="w-8 h-8 text-emerald-500" />
          </div>
          <h2 className="text-xl font-bold text-emerald-700 dark:text-emerald-300 mb-2">DÃ©claration EnregistrÃ©e! â€” ØªÙ… Ø§Ù„ØªØ³Ø¬ÙŠÙ„!</h2>
          {declarationId && (
            <p className="text-sm text-gray-500 dark:text-gray-400 mb-1">NumÃ©ro: <strong className="text-gray-800 dark:text-white">INC-{new Date().getFullYear()}-{String(declarationId).padStart(6, '0')}</strong></p>
          )}
          <p className="text-sm text-gray-500 dark:text-gray-400 mb-4">Hadchi kollo tssajjal m3a sawtk bla ma ktebti walo.</p>

          {Object.keys(formData).length > 0 && (
            <div className="text-left bg-gray-50 dark:bg-gray-900 rounded-xl p-4 mb-4">
              <h3 className="text-sm font-bold text-gray-700 dark:text-gray-300 mb-2">RÃ©sumÃ©:</h3>
              <div className="space-y-1">
                {Object.entries(formData).filter(([k, v]) => v && k !== "ready").map(([k, v]) => (
                  <div key={k} className="flex justify-between text-xs">
                    <span className="text-gray-500 dark:text-gray-400">{k}</span>
                    <span className="font-medium text-gray-800 dark:text-gray-200">{v}</span>
                  </div>
                ))}
              </div>
            </div>
          )}

          <button onClick={startSession}
            className="px-6 py-2 bg-blue-500 hover:bg-blue-600 text-white rounded-xl font-bold text-sm flex items-center gap-2 mx-auto">
            <RefreshCw className="w-4 h-4" /> Nouvelle DÃ©claration
          </button>
        </div>
      )}

      {/* Cancelled */}
      {cancelled && (
        <div className="bg-white dark:bg-gray-800 rounded-2xl shadow-lg border-2 border-amber-300 dark:border-amber-700 p-6 text-center">
          <div className="w-16 h-16 mx-auto bg-amber-100 dark:bg-amber-900/30 rounded-full flex items-center justify-center mb-4">
            <XCircle className="w-8 h-8 text-amber-500" />
          </div>
          <h2 className="text-xl font-bold text-amber-700 dark:text-amber-300 mb-2">DÃ©claration AnnulÃ©e</h2>
          <p className="text-sm text-gray-500 dark:text-gray-400 mb-4">Machi mochkil! 3awed t3awed men birri3la l'boton.</p>
          <button onClick={startSession}
            className="px-6 py-2 bg-blue-500 hover:bg-blue-600 text-white rounded-xl font-bold text-sm flex items-center gap-2 mx-auto">
            <RefreshCw className="w-4 h-4" /> Recommencer
          </button>
        </div>
      )}
    </div>
  );
}
